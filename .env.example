# CubelessMail Environment Configuration
# Copy this file to .env and fill in your values

# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here

# Email Account (optional - can be set via admin or setup_account command)
# EMAIL_ADDRESS=your-email@gmail.com
# EMAIL_PASSWORD=your-password
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USE_SSL=True
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=True

# Database (optional - defaults to SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/cubelessmail

# Allowed Hosts
# ALLOWED_HOSTS=localhost,127.0.0.1

# Email Credential Encryption
# REQUIRED for production. Generate a key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Then paste the output here:
MAIL_ENCRYPTION_KEY=your-fernet-key-here
