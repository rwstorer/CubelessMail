# CubelessMail Environment Configuration
# Copy this file to .env and fill in your values

# Runtime environment: local, staging, production
DJANGO_ENV=local

# Django Settings
# Local default can remain True. In production, set to False.
DEBUG=True

# REQUIRED in production. Keep secret and never commit.
DJANGO_SECRET_KEY=replace-with-strong-secret-key

# Database (optional - defaults to SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/cubelessmail

# Allowed Hosts (required in production)
# ALLOWED_HOSTS=mail.example.com,www.mail.example.com

# CSRF trusted origins (required when behind HTTPS domain/proxy)
# CSRF_TRUSTED_ORIGINS=https://mail.example.com,https://www.mail.example.com

# Security settings (production-safe defaults are automatic when DJANGO_ENV=production)
# Override only when needed.
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=False
# SECURE_CONTENT_TYPE_NOSNIFF=True

# Set True only when behind a trusted reverse proxy that sets X-Forwarded-Proto
# TRUST_PROXY_SSL_HEADER=True

# Authentication lockout (django-axes)
# Local defaults keep this off to avoid dev lockouts.
# Production defaults enable this automatically unless overridden.
# AXES_ENABLED=True
# AXES_FAILURE_LIMIT=5
# AXES_COOLOFF_MINUTES=30
# AXES_RESET_ON_SUCCESS=True

# Admin IP allowlist for /admin/
# Production defaults enable this automatically unless overridden.
# ADMIN_IP_ALLOWLIST_ENABLED=True
# ADMIN_IP_ALLOWLIST=203.0.113.10,198.51.100.0/24
# Set True only if a trusted reverse proxy sets X-Forwarded-For correctly.
# ADMIN_IP_ALLOWLIST_TRUST_X_FORWARDED_FOR=False

# Email Credential Encryption
# REQUIRED for production. Generate a key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Then paste the output here:
MAIL_ENCRYPTION_KEY=your-fernet-key-here
